<BoxContainer xmlns="https://spacestation14.io"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              Orientation="Horizontal"
              SeparationOverride="3"
              RectClipContent="True"
              HorizontalExpand="False"
              HorizontalAlignment="Center">
    <Button Name="MinusButton" Text="-" MinSize="24 24"/>
    <Label Name="QtyLabel" Visible="False" MinWidth="0" HorizontalAlignment="Center"/>
    <LineEdit Name="QtyEdit" MinWidth="36" HorizontalExpand="False"/>
    <Button Name="PlusButton" Text="+" MinSize="24 24"/>
</BoxContainer>
