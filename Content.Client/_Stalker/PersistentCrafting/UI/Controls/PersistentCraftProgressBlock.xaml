<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         HorizontalExpand="True">
    <PanelContainer Name="RootPanel" HorizontalExpand="True">
        <BoxContainer Name="Body"
                      Orientation="Vertical"
                      HorizontalExpand="True">
            <Label Name="TitleLabel"/>
            <Control MinSize="1 6"/>
            <Label Name="MainTextLabel"/>
            <Control MinSize="1 6"/>
            <ProgressBar Name="ProgressBar"
                         MinSize="0 8"
                         HorizontalExpand="True"/>
            <Control Name="FooterSpacer" MinSize="1 6"/>
            <Label Name="FooterLabel"/>
        </BoxContainer>
    </PanelContainer>
</Control>
