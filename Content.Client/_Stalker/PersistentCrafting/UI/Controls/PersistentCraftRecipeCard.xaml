<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         HorizontalExpand="True">
    <ContainerButton Name="RootButton"
                     HorizontalExpand="True"
                     MinSize="0 76">
        <BoxContainer Orientation="Horizontal"
                      HorizontalExpand="True">
            <PanelContainer Name="IconPanel"
                            MinSize="48 48" />
            <Control MinSize="10 1" />
            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True">
                <BoxContainer Orientation="Horizontal"
                              HorizontalExpand="True">
                    <Label Name="TitleLabel"
                           HorizontalExpand="True"
                           ClipText="True" />
                    <Control MinSize="8 1" />
                    <BoxContainer Name="StatusHost"
                                  Orientation="Horizontal" />
                </BoxContainer>
                <Control MinSize="1 4" />
                <Label Name="SecondaryLabel"
                       ClipText="True" />
            </BoxContainer>
        </BoxContainer>
    </ContainerButton>
</Control>
